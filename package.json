{
  "name": "mini-commerce-engineering-playground",
  "version": "0.0.0",
  "private": true,
  "description": "Engineering playground for a fictional mini-commerce store.",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:contract": "turbo run test:contract",
    "test:e2e": "turbo run test:e2e",
    "test:perf:smoke": "./dev perf:smoke",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "pg:doctor": "./dev doctor",
    "pg:up": "./dev up",
    "pg:restart": "./dev restart",
    "pg:dev": "./dev dev",
    "pg:dev:host": "./dev dev:host",
    "pg:status": "./dev status",
    "pg:smoke": "./dev smoke",
    "pg:seed": "./dev seed",
    "pg:reset": "./dev reset",
    "pg:down": "./dev down",
    "pg:logs": "./dev logs",
    "pg:open": "./dev open",
    "pg:hack": "./dev hack",
    "pg:perf:smoke": "./dev perf:smoke",
    "pg:perf:checkout-flow": "./dev perf:checkout-flow",
    "pg:perf:read-heavy": "./dev perf:read-heavy",
    "pg:perf:open-report": "./dev perf:open-report",
    "pg:perf:clean": "./dev perf:clean",
    "pg:test": "python3 -c \"import sys; sys.path.insert(0,'scripts'); import unittest; loader=unittest.TestLoader(); suite=loader.discover('scripts/pg/tests'); runner=unittest.TextTestRunner(verbosity=2); sys.exit(0 if runner.run(suite).wasSuccessful() else 1)\"",
    "pg:blender:export": "scripts/blender/export.sh"
  },
  "devDependencies": {
    "next": "^14.2.0",
    "turbo": "latest"
  }
}
