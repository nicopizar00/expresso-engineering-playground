# Copy this file to .env at the repo root for local development.
# .env is gitignored — never commit real values.
# All pnpm pg:* commands load this file automatically.

POSTGRES_USER=playground
POSTGRES_PASSWORD=playground
POSTGRES_DB=mini_commerce_playground
DATABASE_URL=postgres://playground:playground@localhost:5432/mini_commerce_playground
BFF_PORT=3001
WEB_PORT=3000
VIZ_PORT=3002
# Prisma Studio admin GUI port (opt-in via ./dev up admin or ./dev up full).
STUDIO_PORT=5555
# Optional override. By default the browser calls the web app's own /api/bff
# proxy (same origin) and never talks to the BFF directly, so this is left
# unwired in compose. Set + pass as a build arg only to bypass the proxy.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# URL the web app uses for the "open standalone in a new tab" visualizer link.
# The browser runs on the host, so this points at the host-mapped visualizer
# port (VIZ_PORT). Baked into the web image at build time; keep in sync with
# VIZ_PORT.
NEXT_PUBLIC_VISUALIZER_URL=http://localhost:3002
# URL the web app links to for the Prisma Studio admin GUI. Leave unset to
# hide the "Admin" link in the header and on /dev. Direct DB access — does
# NOT fire domain events, so the visualizer won't react to edits made here
# until the page is reloaded. Keep in sync with STUDIO_PORT.
NEXT_PUBLIC_PRISMA_STUDIO_URL=http://localhost:5555
# OTLP endpoint used by host-side processes (e.g. k6 host mode).
# The BFF container reaches the collector by service name and ignores
# this value — see infra/docker/compose.yaml.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Observability profile (./dev up obs) ---------------------------------
# Grafana UI port. Note: Grafana's container listens on :3000 internally;
# we map to :3030 on the host so it does not collide with the Next.js web
# app. Change here if 3030 is taken locally.
GRAFANA_PORT=3030
# Optional: Grafana admin credentials. Anonymous viewer is enabled by
# default in compose, so most exploration does not need login.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
TEMPO_PORT=3200

# --- Web app internal service proxy (server-side only) ---------------------
# The browser only ever talks to the web app; the Next.js server proxies to the
# other containers over the internal Docker network (next.config.mjs rewrites).
# Compose sets these to the in-container service names automatically, so leave
# them unset here: host dev (pnpm pg:dev:host) must fall back to localhost, and
# uncommenting them would break it.
# BFF_INTERNAL_URL=http://bff:3001
# VISUALIZER_INTERNAL_URL=http://visualizer-3d:80
