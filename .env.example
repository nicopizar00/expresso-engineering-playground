# Root environment example.
# Copy relevant sections into a local .env file at the package level.
# Root-level .env files are gitignored — never commit real values.

# --- BFF / API ---
# PORT=3001
# NODE_ENV=development
# DATABASE_URL=postgres://playground:playground@localhost:5432/mini_commerce_playground
# CORS_ORIGIN=http://localhost:3000

# --- Web app ---
# See apps/web/.env.example for web-specific variables.

# --- Observability ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=mini-commerce-bff
