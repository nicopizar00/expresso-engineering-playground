# Copy this file to .env at the repo root for local development.
# .env is gitignored — never commit real values.
# All pnpm pg:* commands load this file automatically.

POSTGRES_USER=playground
POSTGRES_PASSWORD=playground
POSTGRES_DB=mini_commerce_playground
DATABASE_URL=postgres://playground:playground@localhost:5432/mini_commerce_playground
BFF_PORT=3001
WEB_PORT=3000
VIZ_PORT=3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# URL the web app uses to embed/link the standalone 3D visualizer. The browser
# runs on the host, so this points at the host-mapped visualizer port (VIZ_PORT).
# Baked into the web image at build time; keep in sync with VIZ_PORT.
NEXT_PUBLIC_VISUALIZER_URL=http://localhost:3002
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
