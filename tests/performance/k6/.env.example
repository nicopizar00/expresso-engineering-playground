# Performance testing environment example.
# Copy to .env (gitignored) and adjust per environment.
#
# No secrets, no internal URLs, no proprietary data — this file is
# committed and reviewed.

# Base URL the k6 scenarios target.
# - Local + direct k6 binary on host: http://localhost:3001
# - Local + k6 via Docker Compose:    http://host.docker.internal:3001
BASE_URL=http://localhost:3001

# Scenario name. Today only `smoke` is wired; `load` and `stress` slots
# exist for the imported k6 project to populate.
SCENARIO=smoke

# Environment label. Surfaced as a tag on every k6 metric so dashboards
# can split local / CI / staging runs apart.
K6_ENV=local

# Where summary JSON and any other generated artifacts land. Relative
# paths are resolved from the repo root.
REPORT_OUTPUT=tests/performance/k6/reports
