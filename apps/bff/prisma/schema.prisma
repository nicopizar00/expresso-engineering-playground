// Prisma schema placeholder for the travel booking playground.
//
// Intentionally empty in this iteration. The next iteration will introduce
// minimal models per domain module, kept thin to avoid premature persistence
// decisions:
//   - User (users module)
//   - Trip, TripLeg (trips module)
//   - Booking (booking module)
//   - Order, Payment (orders module)
//
// Connection URL must come from DATABASE_URL — never hardcoded.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

