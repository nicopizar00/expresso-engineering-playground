generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               Int      @id @default(autoincrement())
  productId        String   @unique
  sku              String   @unique
  name             String
  description      String
  category         String
  priceAmountMinor Int
  priceCurrency    String
  inventory        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
