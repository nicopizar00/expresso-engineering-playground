# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real values.

# Base URL of the BFF / API. Defaults to http://localhost:3001 if not set.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# URL of the standalone 3D visualizer app (for iframe embedding).
# Start with ./scripts/visualizer-up.sh for local development.
# Leave empty to show configuration instructions on the /visualizer page.
# TODO(api-wire): Set per-environment in deployment config
NEXT_PUBLIC_VISUALIZER_URL=http://localhost:3002

# Enable demo mode by default (uses mock data, no backend required).
# Set to "true" for demo environments or quick UI exploration.
NEXT_PUBLIC_DEMO_MODE=false
