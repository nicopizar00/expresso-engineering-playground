#!/usr/bin/env bash
# ./dev — Docker-first developer CLI for mini-commerce playground.
#
# Implementation lives in scripts/pg/ (Python ≥ 3.9, stdlib only).
# This file is a 4-line trampoline so the muscle memory keeps working.
# Requires: Docker Desktop + Python 3.9+ (system Python on macOS works).

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PYTHON="${PYTHON:-python3}"
if ! command -v "$PYTHON" >/dev/null 2>&1; then
  echo "ERROR: python3 not found. Install Python 3.9+ or set PYTHON=/path/to/python." >&2
  exit 1
fi

cd "$REPO_ROOT/scripts"
exec "$PYTHON" -m pg "$@"
