#!/usr/bin/env bash
# ./dev — Docker-first developer CLI for mini-commerce playground.
#
# Requires: Docker Desktop (bash is built-in on macOS — no Node, no pnpm on the host).
# Optional: brew install go-task  (thin Taskfile.yml wrappers that call this script)
#
# Usage: ./dev <command> [args]
#   up [core|web|viz|full]   Start the local stack            (default: core)
#   down                     Stop all services
#   restart [target]         Stop then start
#   dev                      Hot-reload via docker compose watch
#   status                   Show running service status
#   logs                     Stream compose logs
#   smoke                    Hit all endpoints and assert 200/201
#   seed                     Run prisma db seed
#   open                     Print local URLs
#   doctor                   Validate prerequisites
#   perf:smoke               Run k6 smoke profile in Docker
#   perf:clean               Delete k6 reports

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$REPO_ROOT"

COMPOSE_FILE="infra/docker/compose.yaml"
COMPOSE_DEV_FILE="infra/docker/compose.dev.yaml"
PERF_COMPOSE_FILE="infra/docker/compose.performance.yaml"
PERF_REPORTS_DIR="tests/performance/k6/reports"

# Load root .env (gitignored); silently skip if absent.
if [[ -f .env ]]; then
  # shellcheck disable=SC1091
  set -a; source .env; set +a
fi

BFF_PORT="${BFF_PORT:-3001}"
WEB_PORT="${WEB_PORT:-3000}"
VIZ_PORT="${VIZ_PORT:-3002}"
API_BASE="http://localhost:${BFF_PORT}"

# ANSI helpers — degrade when NO_COLOR is set or output is not a TTY.
if [[ -z "${NO_COLOR:-}" && -t 1 ]]; then
  GR='\033[32m' RD='\033[31m' YL='\033[33m' BD='\033[1m' DM='\033[2m' RS='\033[0m'
else
  GR='' RD='' YL='' BD='' DM='' RS=''
fi

pass()   { printf "  ${GR}✓${RS} %s\n" "$1"; }
fail()   { printf "  ${RD}✗${RS} %s\n" "$1"; }
warn()   { printf "  ${YL}!${RS} %s\n" "$1"; }
info()   { printf "  ${DM}→${RS} %s\n" "$1"; }
header() { printf "\n${BD}%s${RS}\n\n" "$1"; }

port_in_use() { nc -z 127.0.0.1 "$1" 2>/dev/null; }

compose() { docker compose -f "$COMPOSE_FILE" "$@"; }

# Run a one-off BFF container using the dev-stage image (has ts-node + all devDeps).
# The dev override switches the build target to 'dev'; DATABASE_URL and other env vars
# are inherited from the bff service definition in compose.yaml. --no-deps skips
# re-starting postgres (it's already up at this point in the up flow).
compose_run_bff_dev() {
  docker compose -f "$COMPOSE_FILE" -f "$COMPOSE_DEV_FILE" run --rm --no-deps bff "$@"
}

# ---------------------------------------------------------------------------
# doctor — validate local prerequisites
# ---------------------------------------------------------------------------

cmd_doctor() {
  header "Playground Doctor"
  local all_ok=true

  if command -v docker &>/dev/null; then
    if docker info &>/dev/null 2>&1; then
      pass "Docker $(docker --version | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')"
    else
      fail "Docker found but not responding — is Docker Desktop running?"
      all_ok=false
    fi
  else
    fail "docker not found — install Docker Desktop"
    all_ok=false
  fi

  if docker compose version &>/dev/null 2>&1; then
    pass "$(docker compose version)"
  else
    fail "docker compose not available — update Docker Desktop to 4.x+"
    all_ok=false
  fi

  if [[ -f .env ]]; then
    pass ".env exists"
  else
    warn ".env not found — run: cp .env.example .env"
    all_ok=false
  fi

  echo ""
  if port_in_use "$BFF_PORT"; then
    pass "Port ${BFF_PORT} (BFF) is responding — service is running"
  else
    info "Port ${BFF_PORT} (BFF) not in use — run ./dev up to start"
  fi
  if port_in_use "$WEB_PORT"; then
    pass "Port ${WEB_PORT} (web) is responding — service is running"
  else
    info "Port ${WEB_PORT} (web) not in use — run ./dev up web to start"
  fi

  echo ""
  if [[ "$all_ok" == "true" ]]; then
    printf "${GR}All required prerequisites are available.${RS}\n\n"
  else
    printf "${RD}Some prerequisites are missing — resolve the issues above.${RS}\n\n"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# up — start local infrastructure with optional target
# ---------------------------------------------------------------------------

cmd_up() {
  local target="${1:-core}"
  case "$target" in
    core|web|viz|full) ;;
    *) printf "${RD}Unknown target '%s'. Use: core | web | viz | full${RS}\n" "$target"; exit 1 ;;
  esac

  header "Starting local app stack (${target})..."

  # Port collision pre-flight. `up` is additive: if our own bff container already
  # holds the port, `compose up -d` will reconcile in place — no need to tear
  # down profiled siblings (web/viz) the user may still want running. Only error
  # out when the port is held by something we don't control.
  if port_in_use "$BFF_PORT"; then
    if compose ps --services --filter status=running 2>/dev/null | grep -qx bff; then
      info "Port ${BFF_PORT} held by our bff container — reconciling in place"
    else
      fail "Port ${BFF_PORT} occupied by a non-Docker process."
      info "Kill the blocking process: lsof -ti:${BFF_PORT} | xargs kill"
      info "Or stop the stack: ./dev down"
      exit 1
    fi
  fi

  # 1. Start postgres + otel-collector and wait for healthy.
  compose up -d --wait postgres otel-collector
  pass "Postgres is healthy"

  # 2. Run schema migrations in a one-off dev-stage BFF container (no host pnpm needed).
  info "Running prisma migrate deploy..."
  compose_run_bff_dev pnpm --filter @mini-commerce/bff exec prisma migrate deploy
  pass "Schema is up to date"

  # 3. Seed (idempotent — seed.ts uses upsert).
  info "Running prisma db seed..."
  compose_run_bff_dev pnpm --filter @mini-commerce/bff exec prisma db seed
  pass "Seed complete"

  # 4. Start BFF and wait for healthy.
  compose up -d --wait bff
  pass "BFF is running on http://localhost:${BFF_PORT}"

  # 5. Optional profiled services.
  if [[ "$target" == "web" || "$target" == "full" ]]; then
    compose --profile web up -d --wait web
    pass "Web is running on http://localhost:${WEB_PORT}"
  fi
  if [[ "$target" == "viz" || "$target" == "full" ]]; then
    compose --profile viz up -d --wait visualizer-3d
    pass "Visualizer is running on http://localhost:${VIZ_PORT}"
  fi

  echo ""
  info "Run ${BD}./dev dev${RS} for hot-reload (docker compose watch)"
  info "Run ${BD}./dev status${RS} to check service health"
  echo ""
}

# ---------------------------------------------------------------------------
# down — stop all services
# ---------------------------------------------------------------------------

cmd_down() {
  header "Stopping services..."
  compose --profile web --profile viz down
  echo ""; pass "Services stopped."; echo ""
}

# ---------------------------------------------------------------------------
# restart — stop then start
# ---------------------------------------------------------------------------

cmd_restart() {
  local target="${1:-full}"
  header "Restarting (${target})..."
  compose --profile web --profile viz down
  pass "Services stopped"; echo ""
  cmd_up "$target"
}

# ---------------------------------------------------------------------------
# dev — docker compose watch (hot-reload for bff + web)
# ---------------------------------------------------------------------------

cmd_dev() {
  header "Starting dev stack (docker compose watch)..."
  printf "${DM}Tip: run ./dev up first so Postgres is healthy and migrations are applied.\n\nCtrl+C to stop.${RS}\n\n"
  docker compose -f "$COMPOSE_FILE" -f "$COMPOSE_DEV_FILE" --profile web watch
}

# ---------------------------------------------------------------------------
# status — show running service health and ports
# ---------------------------------------------------------------------------

cmd_status() {
  header "Service Status"
  # Include the web/viz profiles so containers in those profiles are visible
  # even when stopped — otherwise a crashed/exited visualizer is silently
  # hidden and looks identical to "never asked to start it". `-a` shows
  # exited containers so the user sees the actual state, not a curated view.
  local containers
  containers=$(compose --profile web --profile viz ps -a --quiet 2>/dev/null) || true
  if [[ -z "$containers" ]]; then
    info "No services running. Run ./dev up to start."
  else
    compose --profile web --profile viz ps -a
  fi
  echo ""
}

# ---------------------------------------------------------------------------
# logs — stream compose logs
# ---------------------------------------------------------------------------

cmd_logs() {
  header "Docker Compose logs"
  printf "${DM}Streaming (Ctrl+C to stop)...${RS}\n\n"
  docker compose -f "$COMPOSE_FILE" logs --follow
}

# ---------------------------------------------------------------------------
# smoke — minimal endpoint validation using curl
# ---------------------------------------------------------------------------

cmd_smoke() {
  header "Playground Smoke Test"
  printf "${DM}Target: ${API_BASE}${RS}\n\n"
  local passed=0 total=0

  smoke_check() {
    local label="$1" method="$2" url="$3" expected="$4"
    shift 4
    total=$((total + 1))
    local actual
    actual=$(curl -s -o /dev/null -w "%{http_code}" -X "$method" "$@" "$url" 2>/dev/null || echo "000")
    if [[ "$actual" == "$expected" ]]; then
      pass "$label"; passed=$((passed + 1))
    else
      fail "${label}  — got HTTP ${actual}, expected ${expected}"
    fi
  }

  smoke_check "GET  /health"                           GET  "${API_BASE}/health"                         200
  smoke_check "GET  /catalog/products"                 GET  "${API_BASE}/catalog/products"               200
  smoke_check "GET  /catalog/products/prod_espresso"   GET  "${API_BASE}/catalog/products/prod_espresso" 200
  smoke_check "POST /cart/items" POST "${API_BASE}/cart/items" 201 \
    -H "Content-Type: application/json" -d '{"productId":"prod_espresso","quantity":2}'
  # Add a second line so the PATCH/DELETE checks can mutate one item while
  # leaving the cart non-empty for the checkout step below.
  smoke_check "POST /cart/items (2nd)" POST "${API_BASE}/cart/items" 201 \
    -H "Content-Type: application/json" -d '{"productId":"prod_espresso","quantity":1}'
  smoke_check "GET  /cart"                             GET  "${API_BASE}/cart"                           200
  # Resolve a real itemId from the cart so the checks don't depend on the
  # in-memory sequence counter (robust across repeated runs).
  local cart_item_id
  cart_item_id=$(curl -s "${API_BASE}/cart" | grep -o '"itemId":"[^"]*"' | head -1 | cut -d'"' -f4)
  cart_item_id="${cart_item_id:-ci_001}"
  smoke_check "PATCH /cart/items/:id" PATCH "${API_BASE}/cart/items/${cart_item_id}" 200 \
    -H "Content-Type: application/json" -d '{"quantity":3}'
  smoke_check "DELETE /cart/items/:id"                 DELETE "${API_BASE}/cart/items/${cart_item_id}"   200
  smoke_check "POST /checkout" POST "${API_BASE}/checkout" 201 \
    -H "Content-Type: application/json" -d '{"customerName":"Smoke Customer"}'
  smoke_check "GET  /orders/ord_demo"                  GET  "${API_BASE}/orders/ord_demo"                200
  smoke_check "POST /orders/ord_demo/manage (mark_prepared)" POST \
    "${API_BASE}/orders/ord_demo/manage" 202 \
    -H "Content-Type: application/json" -d '{"action":"mark_prepared"}'
  smoke_check "GET  /visualization-data"               GET  "${API_BASE}/visualization-data"             200

  # SSE check: open the stream, assert Content-Type and at least one data frame.
  total=$((total + 1))
  local sse_output
  sse_output=$(curl -s -N -H 'Accept: text/event-stream' --max-time 3 \
    "${API_BASE}/visualization-updates" 2>/dev/null || true)
  if echo "$sse_output" | grep -q "^data:"; then
    pass "GET  /visualization-updates (SSE)"; passed=$((passed + 1))
  else
    fail "GET  /visualization-updates (SSE) — no data frame received"
  fi

  echo ""
  if [[ "$passed" -eq "$total" ]]; then
    printf "${GR}All ${total} smoke checks passed.${RS}\n\n"
  else
    printf "${RD}${passed}/${total} smoke checks passed.${RS}\n\n"
    info "Ensure the BFF is running: ./dev up"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# seed — run prisma db seed
# ---------------------------------------------------------------------------

cmd_seed() {
  header "Seed"
  info "Running prisma db seed..."
  compose_run_bff_dev pnpm --filter @mini-commerce/bff exec prisma db seed
  pass "Seed complete."; echo ""
}

# ---------------------------------------------------------------------------
# open — print local URLs
# ---------------------------------------------------------------------------

cmd_open() {
  header "Local URLs"
  printf "  Web app         ${GR}http://localhost:${WEB_PORT}${RS}  (entry point — links every surface)\n"
  printf "  BFF / API       ${GR}http://localhost:${BFF_PORT}${RS}\n"
  printf "  Health endpoint ${GR}http://localhost:${BFF_PORT}/health${RS}\n"
  printf "  3D Visualizer   ${GR}http://localhost:${VIZ_PORT}${RS}  (standalone; embedded at /visualizer, needs 'up viz' or 'up full')\n"
  printf "  OTLP HTTP       ${DM}http://localhost:4318${RS}  (otel-collector)\n"
  printf "  OTLP gRPC       ${DM}http://localhost:4317${RS}  (otel-collector)\n\n"
  printf "${DM}See docs/local-development.md for full setup instructions.${RS}\n\n"
}

# ---------------------------------------------------------------------------
# perf:smoke — run the k6 smoke scenario via Docker Compose
# ---------------------------------------------------------------------------

cmd_perf_smoke() {
  header "Performance smoke (k6)"
  local base_url="${BASE_URL:-http://host.docker.internal:${BFF_PORT}}"
  local scenario="scenarios/smoke/smoke.js"
  local summary_path="/scripts/reports/smoke-summary.json"

  info "Target  : ${base_url}"
  info "Scenario: ${scenario}"
  info "Summary : ${PERF_REPORTS_DIR}/smoke-summary.json"
  echo ""

  if ! port_in_use "$BFF_PORT"; then
    warn "BFF does not appear to be listening on :${BFF_PORT} — run ./dev up first"
    echo ""
  fi

  docker compose -f "$PERF_COMPOSE_FILE" run --rm \
    -e "BASE_URL=${base_url}" k6 run \
    --summary-export "$summary_path" "/scripts/${scenario}"

  echo ""
  pass "k6 smoke completed."
  info "Summary written to ${PERF_REPORTS_DIR}/smoke-summary.json"
  echo ""
}

# ---------------------------------------------------------------------------
# perf:clean — remove generated performance reports
# ---------------------------------------------------------------------------

cmd_perf_clean() {
  header "Cleaning k6 reports"
  if [[ ! -d "$PERF_REPORTS_DIR" ]]; then
    info "${PERF_REPORTS_DIR} does not exist — nothing to clean."
    echo ""; return
  fi
  local removed=0
  for f in "$PERF_REPORTS_DIR"/*; do
    [[ "$(basename "$f")" == ".gitkeep" ]] && continue
    rm -rf "$f"; removed=$((removed + 1))
  done
  pass "Removed ${removed} report artifact(s)."; echo ""
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------

case "${1:-}" in
  up)         cmd_up "${2:-core}" ;;
  down)       cmd_down ;;
  restart)    cmd_restart "${2:-full}" ;;
  dev)        cmd_dev ;;
  status)     cmd_status ;;
  logs)       cmd_logs ;;
  smoke)      cmd_smoke ;;
  seed)       cmd_seed ;;
  open)       cmd_open ;;
  doctor)     cmd_doctor ;;
  perf:smoke) cmd_perf_smoke ;;
  perf:clean) cmd_perf_clean ;;
  *)
    printf "\n${BD}dev — Docker-first developer CLI${RS}\n\n"
    printf "Requires: Docker Desktop  |  No Node, pnpm, or other host tools needed.\n\n"
    printf "Usage: ${BD}./dev <command> [args]${RS}\n\n"
    printf "Commands:\n"
    for cmd in "up [core|web|viz|full]" down "restart [target]" dev status logs smoke seed open doctor perf:smoke perf:clean; do
      printf "  ./dev ${BD}%s${RS}\n" "$cmd"
    done
    echo ""
    [[ -n "${1:-}" ]] && exit 1 || exit 0
    ;;
esac
