# Root .dockerignore for the mini-commerce playground.
#
# All app images (bff, web, …) use the repo root as their build context
# so the pnpm workspace, packages/*, and any apps/* directory are visible.
# Docker only consults the .dockerignore at the context root, so this
# single file governs what every image build sees. Keep entries here
# universal — anything that should be excluded for just one image
# belongs in `apps/<name>/Dockerfile.dockerignore` next to that
# Dockerfile, not here.

# Node / pnpm
**/node_modules
**/.pnpm-store
**/.pnpm-debug.log
**/.turbo

# Build outputs
**/dist
**/.next
**/coverage

# Version control & editor
.git
.gitignore
.gitattributes
.editorconfig
.vscode
.idea

# Env files — never bake into images
.env
.env.*
**/.env
**/.env.*
!.env.example

# Test suites no image needs at build time
tests/e2e
tests/contract
tests/integration
tests/performance

# Docs and infra not consumed at build time
docs
infra/observability
.github

# Local Claude / agent state
.claude
